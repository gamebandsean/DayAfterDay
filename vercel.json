{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "game.js",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "questions.json",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/api/oracle$",
      "dest": "/api/oracle.js"
    },
    {
      "src": "^/api/oracle-portrait$",
      "dest": "/api/oracle-portrait.js"
    },
    {
      "src": "^/api/generate-image$",
      "dest": "/api/generate-image.js"
    },
    {
      "src": "^/game.js$",
      "dest": "/game.js"
    },
    {
      "src": "^/styles.css$",
      "dest": "/styles.css"
    },
    {
      "src": "^/questions.json$",
      "dest": "/questions.json"
    },
    {
      "src": "^/public/(.*)$",
      "dest": "/public/$1"
    }
  ]
}
