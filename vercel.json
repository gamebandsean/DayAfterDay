{
  "version": 2,
  "headers": [
    {
      "source": "/public/newborns/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/public/newborns/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "game.js",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "questions.json",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/api/oracle$",
      "dest": "/api/oracle.js"
    },
    {
      "src": "^/api/oracle-destiny$",
      "dest": "/api/oracle-destiny.js"
    },
    {
      "src": "^/api/oracle-portrait$",
      "dest": "/api/oracle-portrait.js"
    },
    {
      "src": "^/api/generate-image$",
      "dest": "/api/generate-image.js"
    },
    {
      "src": "^/api/voice$",
      "dest": "/api/voice.js"
    },
    {
      "src": "^/game.js$",
      "dest": "/game.js"
    },
    {
      "src": "^/styles.css$",
      "dest": "/styles.css"
    },
    {
      "src": "^/questions.json$",
      "dest": "/questions.json"
    },
    {
      "src": "^/public/(.*)$",
      "dest": "/public/$1"
    }
  ]
}
